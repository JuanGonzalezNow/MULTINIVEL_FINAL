<?xml version="1.0" encoding="UTF-8"?>
<project name="RPG_Manager_Java-impl" default="default" basedir="..">
    <property file="nbproject/project.properties"/>

    <target name="-init">
        <mkdir dir="${build.classes.dir}"/>
        <mkdir dir="${dist.dir}"/>
    </target>

    <target name="default" depends="run"/>

    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${dist.dir}"/>
    </target>

    <target name="compile" depends="-init">
        <javac srcdir="${src.dir}"
               destdir="${build.classes.dir}"
               classpath="${javac.classpath}"
               source="${javac.source}"
               target="${javac.target}"
               encoding="${source.encoding}"
               includeantruntime="false"/>
    </target>

    <target name="run" depends="compile">
        <java classname="${main.class}" fork="true" classpath="${run.classpath}"/>
    </target>

    <target name="jar" depends="compile">
        <jar destfile="${dist.jar}" basedir="${build.classes.dir}" manifest="${manifest.file}"/>
    </target>
</project>
